WHATSAPP_TOKEN=xxxxEAAOcoBxxxx
WHATSAPP_PHONE_NUMBER_ID=1131xxxx47956
VERIFY_TOKEN=whatchat-verify-123
# OpenAI (https://platform.openai.com/api-keys) — analysis, astrology, questionnaire review/medicine step
OPENAI_API_KEY=xxxxsk-proj-JEFZu6xxxx
# Anthropic (https://console.anthropic.com/settings/keys) — turns the computed
# Kundali (services/jyotish.js) into the astro reading text (astroClaude.js) and
# powers the /api/reading web endpoint (routes/kundali.js)
ANTHROPIC_API_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
# MongoDB Atlas connection string (https://cloud.mongodb.com)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/whatchat?retryWrites=true&w=majority

JWT_SECRET=
ADMIN_SECRET=

# Razorpay (https://dashboard.razorpay.com/app/keys) — ₹399 consultation payment gate
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Secret you set when creating the webhook in the Razorpay dashboard (Settings → Webhooks)
RAZORPAY_WEBHOOK_SECRET=
# Optional: override the fee in paise (default 39900 = ₹399)
PAYMENT_AMOUNT_PAISE=39900
# Optional: public site URL (e.g. https://astrovaidhya.com). Used to send shop
# customers back to their order page after paying via Razorpay.
PUBLIC_BASE_URL=

PORT=3000

# ── Admin payment notifications (email) ─────────────────────────────────────
# SMTP credentials used to email the admin whenever a user completes payment.
# For Gmail, SMTP_PASS is an App Password (not your login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From: address (defaults to SMTP_USER if blank)
SMTP_FROM=
# Where payment-alert emails are sent
ADMIN_EMAIL=

# ── Post-payment handoff (wa.me deep link) ──────────────────────────────────
# Digits-only WhatsApp number the user is sent to after paying, to continue with
# the expert. Optional per-path overrides; both fall back to HANDOFF_WA_NUMBER.
# Leave all blank to keep the old in-chat closing behaviour.
HANDOFF_WA_NUMBER=
HANDOFF_WA_NUMBER_DOCTOR=
HANDOFF_WA_NUMBER_ASTRO=